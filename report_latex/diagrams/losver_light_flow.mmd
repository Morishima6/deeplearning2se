flowchart LR
  %% Compact LOSVER-Light pipeline for paper/report use.
  %% Recommended render size: 1500x850, background #ffffff.

  A["CodeXGLUE / Devign<br/><b>C/C++ function</b><br/>binary vulnerable label"]:::data

  subgraph P["Preprocess"]
    direction TB
    B1["Line split"]:::process
    B2["Code metrics<br/>for shallow baseline"]:::process
  end

  subgraph R["Line-Risk Signal"]
    direction TB
    C1["Static risk scoring<br/>API + pointer + branch + length"]:::signal
    C2["Rank lines"]:::signal
    C3["Select top-k<br/><b>k=5</b>"]:::key
  end

  subgraph I["Input Variants"]
    direction TB
    D1["Vanilla<br/>raw function"]:::variant
    D2["Tag<br/><b>&lt;MOD&gt; risky line &lt;/MOD&gt;</b>"]:::variantStrong
    D3["Tag + Prefix<br/>risk summary + tagged code"]:::variant
  end

  subgraph M["Classifier"]
    direction TB
    E1["Qwen2.5-Coder-1.5B"]:::model
    E2["4-bit QLoRA<br/>sequence classification"]:::model
  end

  subgraph O["Evaluation"]
    direction TB
    F1["Validation F1 threshold"]:::eval
    F2["Test metrics<br/>F1 / ROC-AUC / PR-AUC"]:::eval
    F3["top-k ablation<br/>error review"]:::eval
  end

  G["Finding<br/><b>Tag</b> is the best<br/>line-signal injection"]:::result

  A --> B1 --> C1 --> C2 --> C3
  A --> B2
  B2 -. "Metrics-Baseline" .-> F2
  C3 --> D1 & D2 & D3
  D1 & D2 & D3 --> E1 --> E2
  E2 --> F1 --> F2 --> G
  E2 --> F3 --> G

  classDef data fill:#eaf3ff,stroke:#2b6cb0,stroke-width:2px,color:#12355b;
  classDef process fill:#edf7ed,stroke:#2f855a,stroke-width:2px,color:#1f3b2d;
  classDef signal fill:#fff6df,stroke:#b7791f,stroke-width:2px,color:#51380b;
  classDef key fill:#ffe8cc,stroke:#dd6b20,stroke-width:2px,color:#4a2508;
  classDef variant fill:#f4edff,stroke:#6b46c1,stroke-width:2px,color:#2d1b69;
  classDef variantStrong fill:#eee6ff,stroke:#553c9a,stroke-width:2.5px,color:#24104f;
  classDef model fill:#e6fffb,stroke:#0987a0,stroke-width:2px,color:#064e5a;
  classDef eval fill:#fff0f6,stroke:#b83280,stroke-width:2px,color:#5b123d;
  classDef result fill:#f7fafc,stroke:#2d3748,stroke-width:2px,color:#1a202c;
